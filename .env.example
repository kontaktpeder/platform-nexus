# Copy to .env and fill in values. Never commit .env.

# --- Supabase (required for login + Mission) ---
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- CLI only (migrations: supabase link / db push) — never commit ---
SUPABASE_ACCESS_TOKEN=your_sbp_personal_access_token
SUPABASE_DB_PASSWORD=your_database_password

# Vite client bundle (same values as above, with VITE_ prefix)
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key

# --- Lovable Cloud (required for Gmail + AI brief) ---
LOVABLE_API_KEY=your_lovable_api_key
GOOGLE_MAIL_API_KEY=your_gmail_connector_key

# --- Optional ---
# SLACK_API_KEY=
# MODULE_SECRETS_KEY=64_char_random_string_for_encrypting_module_keys
